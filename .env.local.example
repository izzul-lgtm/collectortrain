# Salin fail ni jadi ".env.local" untuk dev di local machine.
# Untuk production, masukkan value sebenar dalam:
# Vercel Dashboard → Project → Settings → Environment Variables

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Jumpa dalam: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ── AI — Roleplay & Evaluation (Anthropic Claude) ───────────────────────────
# Jumpa dalam: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI — Text-to-Speech / Suara Debtor (Google Gemini) ──────────────────────
# Jumpa dalam: console.cloud.google.com → APIs & Services → Credentials
# ATAU: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI — Speech-to-Text / Suara Collector (Groq Whisper) ────────────────────
# Jumpa dalam: console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
